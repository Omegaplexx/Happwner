<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/dialog_content_padding_top"
    android:paddingBottom="@dimen/spacing_small">

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkProcessManual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dialog_checkbox_margin_start"
        android:layout_marginEnd="@dimen/spacing_normal"
        android:paddingStart="12dp"
        android:paddingEnd="@dimen/spacing_normal"
        android:text="@string/setting_process_manual"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_body"
        app:buttonTint="@color/dialog_control_selector" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkProcessServer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dialog_checkbox_margin_start"
        android:layout_marginEnd="@dimen/spacing_normal"
        android:paddingStart="12dp"
        android:paddingEnd="@dimen/spacing_normal"
        android:text="@string/setting_process_server"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_body"
        app:buttonTint="@color/dialog_control_selector" />

</LinearLayout>
