<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:orientation="vertical">

    <View
        android:id="@+id/statusBarBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/status_bar" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/settingsToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/brand_purple"
            app:titleTextColor="@color/toolbar_text"
            app:theme="@style/ThemeOverlay.Happwner.Toolbar"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/action_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_icon_ripple"
                    android:src="?attr/homeAsUpIndicator"
                    android:contentDescription="@string/btn_back"
                    app:tint="@color/toolbar_text" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/title_settings"
                    android:textColor="@color/toolbar_text"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

                <ImageButton
                    android:id="@+id/action_info"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_icon_ripple"
                    android:src="@drawable/ic_info_filled"
                    android:contentDescription="@string/about_app"
                    app:tint="@color/toolbar_text" />
            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/island_padding">

            <!-- Настройка: Язык -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_language"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_language"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:id="@+id/textLanguageStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/brand_purple_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Настройка: Тема -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_palette"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_theme"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:id="@+id/textThemeStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/brand_purple_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Настройка: Дубликаты -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemShowDuplicates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_filter_none"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_show_duplicates"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_show_duplicates_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchShowDuplicates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@null" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Настройка: Режим LSPatch -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemLSPatchMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_healing"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_lspatch_mode"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:id="@+id/textLSPatchStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/brand_purple_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_lspatch_mode_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Настройка: Обрабатывать ответ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemProcessResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_process"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_process_response"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:id="@+id/textProcessResponseDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_process_response_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Заголовок: Мост подписок -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_bridge_header"
                android:textColor="@color/brand_purple_secondary"
                android:textSize="@dimen/text_size_secondary"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginTop="@dimen/spacing_large"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                android:layout_marginStart="@dimen/spacing_tiny" />

            <!-- Настройка: Включить мост -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemEnableBridge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_dns"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_enable_bridge"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_enable_bridge_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEnableBridge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Настройка: Оптимизация батареи -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemBatteryOpt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/island_margin_bottom"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_battery_saver"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_battery_opt"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:id="@+id/textBatteryStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/brand_purple_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_battery_opt_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Настройка: Watchdog -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemWatchdog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/ui_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/island_stroke"
                app:cardBackgroundColor="@color/island_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_content_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_size_standard"
                        android:layout_height="@dimen/icon_size_standard"
                        android:src="@drawable/ic_timelapse"
                        app:tint="@color/brand_purple_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/card_content_padding"
                        android:layout_marginEnd="@dimen/card_content_padding"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_watchdog"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_label" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_watchdog_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchWatchdog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false"
                        android:background="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
